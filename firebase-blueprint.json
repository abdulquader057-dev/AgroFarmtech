{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores farmer profile information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Farmer's full name" },
        "location": { "type": "string", "description": "Farm location/region" },
        "language": { "type": "string", "enum": ["en", "te", "hi"], "description": "Preferred language" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "location", "language"]
    },
    "LandData": {
      "title": "Land Data",
      "description": "Stores estimated soil data based on land characteristics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "location": { "type": "string" },
        "soilType": { "type": "string" },
        "estimatedMoisture": { "type": "number" },
        "nutrients": {
          "type": "object",
          "properties": {
            "n": { "type": "number" },
            "p": { "type": "number" },
            "k": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "location", "estimatedMoisture", "timestamp"]
    },
    "Product": {
      "title": "Product",
      "description": "Marketplace product listing.",
      "type": "object",
      "properties": {
        "farmerId": { "type": "string" },
        "farmerName": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "stock": { "type": "number" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["farmerId", "name", "price", "unit"]
    },
    "Order": {
      "title": "Order",
      "description": "Marketplace transaction.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "quantity": { "type": "number" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "buyerId", "sellerId", "quantity", "totalPrice", "status"]
    },
    "PestReport": {
      "title": "Pest Report",
      "description": "Records of AI-detected pests and diseases.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "disease": { "type": "string" },
        "confidence": { "type": "number" },
        "solution": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "disease", "confidence", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/sensors/{logId}": {
      "schema": "SensorLog",
      "description": "IoT sensor data logs"
    },
    "/pests/{reportId}": {
      "schema": "PestReport",
      "description": "AI pest detection reports"
    }
  }
}
